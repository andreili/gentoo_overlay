From f8025ca661625f64d3d60aa72b5ddd076eae159d Mon Sep 17 00:00:00 2001
From: Andrey Leonchikov <andreil499@gmail.com>
Date: Tue, 5 May 2026 17:02:01 +0200
Subject: [PATCH] Fix new features compilation.

Co-authored-by: Copilot <copilot@github.com>
---
 src/slic3r/GUI/GUI_App.cpp            | 2 +-
 src/slic3r/GUI/WebUserLoginDialog.cpp | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/slic3r/GUI/GUI_App.cpp b/src/slic3r/GUI/GUI_App.cpp
index 85690ce988..3a9057802e 100644
--- a/src/slic3r/GUI/GUI_App.cpp
+++ b/src/slic3r/GUI/GUI_App.cpp
@@ -7881,7 +7881,7 @@ void GUI_App::preset_deleted_from_cloud(std::string setting_id)
 
     // Delete the .info file after cloud deletion is confirmed
     if (!preset_file_path.empty() && fs::exists(fs::path(preset_file_path))) {
-        boost::nowide::remove(preset_file_path.c_str());
+        boost::filesystem::remove(preset_file_path.c_str());
         BOOST_LOG_TRIVIAL(info) << "Deleted .info file after cloud confirmation: " << preset_file_path;
     }
 
diff --git a/src/slic3r/GUI/WebUserLoginDialog.cpp b/src/slic3r/GUI/WebUserLoginDialog.cpp
index b6d5f055fa..1959b9b860 100644
--- a/src/slic3r/GUI/WebUserLoginDialog.cpp
+++ b/src/slic3r/GUI/WebUserLoginDialog.cpp
@@ -47,7 +47,7 @@ namespace {
 int reserve_loopback_port()
 {
     try {
-        boost::asio::io_service       io_service;
+        boost::asio::io_context       io_service;
         boost::asio::ip::tcp::acceptor acceptor(io_service, {boost::asio::ip::tcp::v4(), 0});
         return static_cast<int>(acceptor.local_endpoint().port());
     } catch (...) {
